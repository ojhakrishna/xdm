{
    "name": "XDM Integration Module",
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icon16.png",
            "48": "icon48.png",
            "128": "icon128.png"
        }
    },
    "manifest_version": 3,
    "version": "4.0",
    "description": "Download with Xtreme Download Manager. Intercepts downloads, captures streaming video, and integrates with XDM for accelerated downloading.",
    "host_permissions": [
        "*://*/*"
    ],
    "permissions": [
        "downloads",
        "cookies",
        "webRequest",
        "tabs",
        "storage",
        "contextMenus",
        "alarms",
        "nativeMessaging"
    ],
    "background": {
        "scripts": ["main.js"],
        "type": "module"
    },
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "xdm-v8-browser-helper@subhra74.github.io",
            "strict_min_version": "109.0"
        }
    }
}
